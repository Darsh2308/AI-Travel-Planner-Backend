PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/ai-travel-planner
MONGO_DB_NAME=ai-travel-planner
LOG_LEVEL=info
JWT_ACCESS_SECRET=replace-with-a-long-random-access-token-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-token-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
GROQ_API_KEY=
GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org
FRONTEND_URL=http://localhost:3000
